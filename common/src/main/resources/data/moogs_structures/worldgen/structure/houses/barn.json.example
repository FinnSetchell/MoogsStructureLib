{
  // Barn structure configuration for Moog's Structure Lib
  // This structure uses the GenericJigsawStructure system for flexible, data-driven generation
  
  "type": "moogs_structures:moogs_structures_generic_jigsaw_structure",

  "start_pool": "moogs_structures:houses/barn/start_pool",

  "size": 1,

  // Biome and terrain generation settings
  "biomes": "#moogs_structures:has_structure/overworld_biomes",
  "project_start_to_heightmap": "WORLD_SURFACE_WG",
  "cannot_spawn_in_liquid": true,
  "terrain_height_radius_check": 1,
  "allowed_terrain_height_range": 3,

  // Structure generation step and terrain adaptation
  "step": "surface_structures",
  "terrain_adaptation": "beard_thin",
  "start_height": {
    "absolute": 0
  },

  // No special spawn overrides needed for this structure
  "spawn_overrides": {}
}